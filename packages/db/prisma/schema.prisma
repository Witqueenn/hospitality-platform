model JobPosting {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String           @map("tenant_id") @db.Uuid
  hotelId               String           @map("hotel_id") @db.Uuid
  slug                  String           @unique
  title                 String
  department            StaffDepartment
  employmentType        EmploymentType   @map("employment_type")
  city                  String
  country               String
  description           String           @db.Text
  salaryMinCents        Int?             @map("salary_min_cents")
  salaryMaxCents        Int?             @map("salary_max_cents")
  currency              String           @default("USD") @db.VarChar(3)
  languages             String[]
  experienceLevel       ExperienceLevel  @default(ENTRY) @map("experience_level")
  accommodationIncluded Boolean          @default(false) @map("accommodation_included")
  mealsIncluded         Boolean          @default(false) @map("meals_included")
  visaSupport           Boolean          @default(false) @map("visa_support")
  isFeatured            Boolean          @default(false) @map("is_featured")
  status                JobPostingStatus @default(DRAFT)
  deadline              DateTime?
  metadata              Json             @default("{}")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id])
  hotel        Hotel                   @relation(fields: [hotelId], references: [id])
  tags         JobPostingTag[]
  requirements JobPostingRequirement[]
  benefits     JobPostingBenefit[]
  applications JobApplication[]

  @@index([tenantId])
  @@index([hotelId])
  @@index([status])
  @@index([city])
  @@index([country])
  @@index([employmentType])
  @@map("job_postings")
}

model JobPostingTag {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postingId String @map("posting_id") @db.Uuid
  tag       String

  posting JobPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([postingId])
  @@map("job_posting_tags")
}

model JobPostingRequirement {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postingId  String  @map("posting_id") @db.Uuid
  label      String
  isRequired Boolean @default(true) @map("is_required")

  posting JobPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([postingId])
  @@map("job_posting_requirements")
}

model JobPostingBenefit {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postingId String @map("posting_id") @db.Uuid
  label     String

  posting JobPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)

  @@index([postingId])
  @@map("job_posting_benefits")
}

model JobApplication {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  postingId   String            @map("posting_id") @db.Uuid
  applicantId String            @map("applicant_id") @db.Uuid
  appType     ApplicationType   @default(OPEN_MARKET) @map("app_type")
  coverLetter String?           @map("cover_letter") @db.Text
  status      ApplicationStatus @default(SUBMITTED)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant         Tenant                     @relation(fields: [tenantId], references: [id])
  posting        JobPosting                 @relation(fields: [postingId], references: [id])
  interviews     JobInterview[]
  statusHistory  ApplicationStatusHistory[]
  recruiterNotes RecruiterNote[]

  @@unique([postingId, applicantId])
  @@index([tenantId])
  @@index([postingId])
  @@index([applicantId])
  @@index([status])
  @@map("job_applications")
}

model JobInterview {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  applicationId  String   @map("application_id") @db.Uuid
  scheduledAt    DateTime @map("scheduled_at")
  format         String   @default("video")
  interviewerIds Json     @default("[]") @map("interviewer_ids")
  notes          String?  @db.Text
  outcome        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  application JobApplication @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
  @@map("job_interviews")
}

model ApplicationStatusHistory {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  applicationId String            @map("application_id") @db.Uuid
  fromStatus    ApplicationStatus @map("from_status")
  toStatus      ApplicationStatus @map("to_status")
  changedBy     String            @map("changed_by") @db.Uuid
  note          String?           @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  application JobApplication @relation(fields: [applicationId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
  @@map("application_status_history")
}

model RecruiterNote {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  applicationId String   @map("application_id") @db.Uuid
  authorId      String   @map("author_id") @db.Uuid
