model StaffProfile {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  hotelId         String          @map("hotel_id") @db.Uuid
  userId          String?         @unique @map("user_id") @db.Uuid
  slug            String          @unique
  name            String
  role            String
  department      StaffDepartment
  languages       String[]
  yearsExperience Int?            @map("years_experience")
  bio             String?         @db.Text
  avgRating       Decimal?        @map("avg_rating") @db.Decimal(3, 2)
  reviewCount     Int             @default(0) @map("review_count")
  isPublic        Boolean         @default(false) @map("is_public")
  tipEnabled      Boolean         @default(false) @map("tip_enabled")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  hotel         Hotel                   @relation(fields: [hotelId], references: [id])
  user          User?                   @relation("StaffUserProfile", fields: [userId], references: [id])
  reviews       StaffGuestReview[]
  conductNotes  StaffGuestConductNote[]
  tips          StaffTip[]
  badges        StaffBadge[]
  gratitudeWall GratitudeWallEntry[]
  recognitions  StaffRecognitionLog[]

  @@index([tenantId])
  @@index([hotelId])
  @@index([department])
  @@map("staff_profiles")
}

model StaffGuestReview {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
