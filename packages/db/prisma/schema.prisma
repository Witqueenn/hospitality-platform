  @@map("bundle_items")
}

// ─────────────────────────────────────────────
// MOBILITY
// ─────────────────────────────────────────────

enum MobilityType {
  AIRPORT_TRANSFER
  RENTAL_CAR
  CHAUFFEUR
  CITY_TRANSFER
  HOURLY_DRIVER
}

model MobilityProvider {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  name            String
  mobilityType    MobilityType @map("mobility_type")
  cities          Json         @default("[]")
  serviceAreas    Json         @default("[]") @map("service_areas")
  contactInfo     Json         @default("{}") @map("contact_info")
  ratingAggregate Decimal?     @map("rating_aggregate") @db.Decimal(3, 2)
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  products MobilityProduct[]

  @@index([tenantId])
  @@map("mobility_providers")
}

model MobilityProduct {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String       @map("tenant_id") @db.Uuid
  mobilityProviderId String       @map("mobility_provider_id") @db.Uuid
  hotelId            String?      @map("hotel_id") @db.Uuid
  name               String
  code               String
  mobilityType       MobilityType @map("mobility_type")
  description        String?      @db.Text
  vehicleClass       String?      @map("vehicle_class")
  capacity           Int?
  baggageCapacity    Int?         @map("baggage_capacity")
  city               String?
  currency           String       @default("USD") @db.VarChar(3)
  pricingConfig      Json         @default("{}") @map("pricing_config")
  priceCents         Int?         @map("price_cents")
  durationMinutes    Int?         @map("duration_minutes")
  isActive           Boolean      @default(true) @map("is_active")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  mobilityProvider MobilityProvider      @relation(fields: [mobilityProviderId], references: [id])
  hotel            Hotel?                @relation(fields: [hotelId], references: [id])
  reservations     MobilityReservation[]

  @@index([tenantId])
  @@index([hotelId])
  @@map("mobility_products")
}

model MobilityReservation {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  mobilityProviderId String   @map("mobility_provider_id") @db.Uuid
  mobilityProductId  String   @map("mobility_product_id") @db.Uuid
  hotelId            String?  @map("hotel_id") @db.Uuid
  guestId            String   @map("guest_id") @db.Uuid
  bookingId          String?  @map("booking_id") @db.Uuid
  pickupAt           DateTime @map("pickup_at")
  pickupLocation     Json     @map("pickup_location")
  dropoffLocation    Json?    @map("dropoff_location")
  passengerCount     Int      @default(1) @map("passenger_count")
  notes              String?  @db.Text
  status             String   @default("PENDING")
  externalRef        String?  @map("external_ref")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  mobilityProduct MobilityProduct @relation(fields: [mobilityProductId], references: [id])
  hotel           Hotel?          @relation(fields: [hotelId], references: [id])
  guest           User            @relation(fields: [guestId], references: [id])

  @@index([tenantId])
  @@index([guestId])
  @@map("mobility_reservations")
}

// ─────────────────────────────────────────────
// CITY GUIDE & LOCAL EXPERIENCE
// ─────────────────────────────────────────────

enum ExperienceCategory {
  FREE_WALK
  CITY_INTRO
  FOOD_TOUR
  NIGHT_TOUR
  BUSINESS_HELPER
  CULTURAL
  SHOPPING
  FAMILY
  OTHER
}

model CityGuide {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  cityCode      String   @map("city_code")
  cityName      String   @map("city_name")
  countryCode   String   @map("country_code")
  languageCode  String   @default("en") @map("language_code")
  summary       String?  @db.Text
  safetyNotes   String?  @map("safety_notes") @db.Text
  transportTips String?  @map("transport_tips") @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  sections    CityGuideSection[]
  experiences LocalExperience[]

  @@index([tenantId])
  @@index([cityCode])
  @@map("city_guides")
}

model CityGuideSection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  cityGuideId String   @map("city_guide_id") @db.Uuid
  sectionKey  String   @map("section_key")
  title       String
  body        String   @db.Text
  persona     String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  cityGuide CityGuide @relation(fields: [cityGuideId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cityGuideId])
  @@map("city_guide_sections")
}

model LocalExperience {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  cityGuideId     String?            @map("city_guide_id") @db.Uuid
  hotelId         String?            @map("hotel_id") @db.Uuid
  slug            String
  name            String
  category        ExperienceCategory
  description     String?            @db.Text
  durationMinutes Int?               @map("duration_minutes")
  city            String?
  maxGuests       Int?               @map("max_guests")
  priceCents      Int?               @map("price_cents")
  currency        String             @default("USD") @db.VarChar(3)
  meetingPoint    Json?              @map("meeting_point")
  languages       Json               @default("[]")
  tags            Json               @default("[]")
  isFree          Boolean            @default(false) @map("is_free")
  isVipExclusive  Boolean            @default(false) @map("is_vip_exclusive")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tenant       Tenant                       @relation(fields: [tenantId], references: [id])
  cityGuide    CityGuide?                   @relation(fields: [cityGuideId], references: [id])
  hotel        Hotel?                       @relation(fields: [hotelId], references: [id])
  slots        LocalExperienceSlot[]
  reservations LocalExperienceReservation[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("local_experiences")
}

model LocalExperienceSlot {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  localExperienceId  String    @map("local_experience_id") @db.Uuid
  startsAt           DateTime  @map("starts_at")
  endsAt             DateTime? @map("ends_at")
  capacity           Int?
  availableCount     Int?      @map("available_count")
  priceOverrideCents Int?      @map("price_override_cents")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")

  localExperience LocalExperience              @relation(fields: [localExperienceId], references: [id], onDelete: Cascade)
  reservations    LocalExperienceReservation[]

  @@index([tenantId])
  @@index([localExperienceId])
  @@map("local_experience_slots")
}

model LocalExperienceReservation {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  guestId               String   @map("guest_id") @db.Uuid
  localExperienceId     String   @map("local_experience_id") @db.Uuid
  localExperienceSlotId String?  @map("local_experience_slot_id") @db.Uuid
  bookingId             String?  @map("booking_id") @db.Uuid
  partySize             Int      @default(1) @map("party_size")
  notes                 String?  @db.Text
  subtotalCents         Int      @default(0) @map("subtotal_cents")
  totalCents            Int      @default(0) @map("total_cents")
  status                String   @default("CONFIRMED")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  guest               User                 @relation(fields: [guestId], references: [id])
  localExperience     LocalExperience      @relation(fields: [localExperienceId], references: [id])
  localExperienceSlot LocalExperienceSlot? @relation(fields: [localExperienceSlotId], references: [id])

  @@index([tenantId])
  @@index([guestId])
  @@map("local_experience_reservations")
}
