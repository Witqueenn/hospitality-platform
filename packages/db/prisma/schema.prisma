model UpsellCampaign {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  hotelId       String?   @map("hotel_id") @db.Uuid
  code          String
  name          String
  triggerType   String    @map("trigger_type")
  targetModule  String    @map("target_module")
  targetId      String?   @map("target_id") @db.Uuid
  displayConfig Json      @default("{}") @map("display_config")
  discountCents Int?      @map("discount_cents")
  discountPct   Int?      @map("discount_pct")
  priority      Int       @default(0)
  startsAt      DateTime? @map("starts_at")
  endsAt        DateTime? @map("ends_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  hotel              Hotel?                       @relation(fields: [hotelId], references: [id])
  recommendationLogs CrossSellRecommendationLog[]

  @@unique([tenantId, code])
  @@index([tenantId, triggerType, isActive])
  @@index([hotelId])
  @@map("upsell_campaigns")
}

model CrossSellRecommendationLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  bookingId         String?  @map("booking_id") @db.Uuid
  campaignId        String?  @map("campaign_id") @db.Uuid
  recommendedModule String   @map("recommended_module")
  recommendedId     String?  @map("recommended_id") @db.Uuid
  score             Decimal? @db.Decimal(5, 4)
  wasShown          Boolean  @default(false) @map("was_shown")
  wasClicked        Boolean  @default(false) @map("was_clicked")
  wasConverted      Boolean  @default(false) @map("was_converted")
  context           Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")

  user     User            @relation("CrossSellLogs", fields: [userId], references: [id])
  booking  Booking?        @relation(fields: [bookingId], references: [id])
  campaign UpsellCampaign? @relation(fields: [campaignId], references: [id])

  @@index([tenantId, userId, createdAt])
  @@index([bookingId])
  @@index([campaignId])
  @@map("cross_sell_recommendation_logs")
}
