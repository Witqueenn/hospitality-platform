// ─────────────────────────────────────────────
// PLATFORM CORE
// ─────────────────────────────────────────────

model Tenant {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String       @unique
  billingPlan String       @default("starter") @map("billing_plan")
  status      TenantStatus @default(ONBOARDING)
  settings    Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  hotels   Hotel[]
  users    User[]
  policies TenantPolicy[]
  bookings Booking[]

  // In-Stay
  guestStaySessions           GuestStaySession[]
  hotelWifiCredentials        HotelWifiCredential[]
  inStayMessages              InStayMessage[]
  hotelVenueMenus             HotelVenueMenu[]
  guestServiceRequests        GuestServiceRequest[]
  serviceTaskAssignments      ServiceTaskAssignment[]
  taskCompletionLogs          TaskCompletionLog[]
  // Incidents
  serviceIncidents            ServiceIncident[]
  serviceResolutions          ServiceResolution[]
  recoveryOffers              RecoveryOffer[]
  recoveryActionLogs          RecoveryActionLog[]
  // Lost & Found
  lostFoundItems              LostFoundItem[]
  lostFoundClaims             LostFoundClaim[]
  // Staff
  staffProfiles               StaffProfile[]
  staffGuestReviews           StaffGuestReview[]
  staffGuestConductNotes      StaffGuestConductNote[]
  staffTips                   StaffTip[]
  staffBadges                 StaffBadge[]
  staffRecognitionLogs        StaffRecognitionLog[]
  gratitudeWallEntries        GratitudeWallEntry[]
  // Jobs
  jobPostings                 JobPosting[]
  jobApplications             JobApplication[]
  jobInterviews               JobInterview[]
  applicationStatusHistories  ApplicationStatusHistory[]
  recruiterNotes              RecruiterNote[]
  // Career
  careerPassports             CareerPassport[]
  // Talent
  talentProfiles              TalentProfile[]
  talentApplications          TalentApplication[]
  // Learning
  staffCourseEnrollments      StaffCourseEnrollment[]
  staffCertificates           StaffCertificate[]
  // Shifts
  shiftPostings               ShiftPosting[]
  shiftClaims                 ShiftClaim[]
  // VIP
  vipPlans                    VipPlan[]
  userVipMemberships          UserVipMembership[]
  vipOffers                   VipOffer[]
  // Flash Inventory
  inventoryFlashWindows       InventoryFlashWindow[]
  nightUsePolicies            NightUsePolicy[]
  // Trusted Stay
  trustedStayHosts            TrustedStayHost[]
  trustedStayUnits            TrustedStayUnit[]
  trustedStayVerifications    TrustedStayVerification[]
  // Amenity
  amenityAssets               AmenityAsset[]
  amenityReservations         AmenityReservation[]
  // Bundle
  bundleOffers                BundleOffer[]
  // Mobility
  mobilityProviders           MobilityProvider[]
  mobilityProducts            MobilityProduct[]
  mobilityReservations        MobilityReservation[]
  // City Guide & Experiences
  cityGuides                  CityGuide[]
  localExperiences            LocalExperience[]
  localExperienceReservations LocalExperienceReservation[]

  @@map("tenants")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  email         String
  emailVerified DateTime? @map("email_verified")
  passwordHash  String?   @map("password_hash")
  name          String
  avatarUrl     String?   @map("avatar_url")
  phone         String?
  role          UserRole  @default(GUEST)
  hotelId       String?   @map("hotel_id") @db.Uuid
  preferences   Json      @default("{}")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id])
  hotel                       Hotel?                       @relation(fields: [hotelId], references: [id])
  bookings                    Booking[]
  supportCasesAsGuest         SupportCase[]                @relation("GuestCases")
  supportCasesAssigned        SupportCase[]                @relation("AssignedCases")
  reviews                     Review[]
  eventRequests               EventRequest[]
  approvals                   ApprovalRequest[]            @relation("Approver")
  sessions                    Session[]
  diningReservations          DiningReservation[]
  nightReservations           NightReservation[]
  guestStaySessions           GuestStaySession[]           @relation("GuestStaySessions")
  staffProfile                StaffProfile?                @relation("StaffUserProfile")
  amenityReservations         AmenityReservation[]
  mobilityReservations        MobilityReservation[]
  localExperienceReservations LocalExperienceReservation[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([hotelId])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model TenantPolicy {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  policyKey   String   @map("policy_key")
  policyValue Json     @map("policy_value")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, policyKey])
  @@map("tenant_policies")
}

// ─────────────────────────────────────────────
// HOTEL CONTEXT
// ─────────────────────────────────────────────

model Hotel {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String      @map("tenant_id") @db.Uuid
  name             String
  slug             String
  description      String?     @db.Text
  shortDescription String?     @map("short_description")
  starRating       Int?        @map("star_rating")
  address          Json
  contactInfo      Json        @default("{}") @map("contact_info")
  policies         Json        @default("{}")
  amenities        Json        @default("[]")
  tags             Json        @default("[]")
  verifiedFields   Json        @default("{}") @map("verified_fields")
  photos           Json        @default("[]")
  noiseNotes       String?     @map("noise_notes") @db.Text
  wifiQuality      String?     @map("wifi_quality")
  status           HotelStatus @default(DRAFT)
  timezone         String      @default("UTC")
  currency         String      @default("USD") @db.VarChar(3)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  staff             User[]
  roomTypes         RoomType[]
  venues            Venue[]
  diningExperiences DiningExperience[]
  nightExperiences  NightExperience[]
  bookings          Booking[]
  eventRequests     EventRequest[]
  supportCases      SupportCase[]
  reviews           Review[]
  hotelInsights     HotelInsight[]

  // In-Stay
  guestStaySessions     GuestStaySession[]
  hotelWifiCredentials  HotelWifiCredential[]
  hotelVenueMenus       HotelVenueMenu[]
  guestServiceRequests  GuestServiceRequest[]
  serviceIncidents      ServiceIncident[]
  lostFoundItems        LostFoundItem[]
  // Staff
  staffProfiles         StaffProfile[]
  gratitudeWallEntries  GratitudeWallEntry[]
  // Jobs
  jobPostings           JobPosting[]
  // Shifts
  shiftPostings         ShiftPosting[]
  // VIP
  vipOffers             VipOffer[]
  // Flash Inventory
  inventoryFlashWindows InventoryFlashWindow[]
  nightUsePolicies      NightUsePolicy[]
  // Trusted Stay
  trustedStayUnits      TrustedStayUnit[]
  // Amenity
  amenityAssets         AmenityAsset[]
  amenityReservations   AmenityReservation[]
  // Bundle
  bundleOffers          BundleOffer[]
  // Mobility
  mobilityProducts      MobilityProduct[]
  mobilityReservations  MobilityReservation[]
  // Local Experience
  localExperiences      LocalExperience[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
  @@map("hotels")
}

// ─────────────────────────────────────────────
// STAY OS
// ─────────────────────────────────────────────

model RoomType {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId               String   @map("hotel_id") @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  name                  String
  description           String?  @db.Text
  capacity              Int
  bedType               String   @map("bed_type")
  sizeSqm               Decimal? @map("size_sqm") @db.Decimal(6, 2)
  floor                 String?
  photos                Json     @default("[]")
  features              Json     @default("[]")
  noiseNotes            String?  @map("noise_notes") @db.Text
  accessibilityFeatures Json     @default("[]") @map("accessibility_features")
  isActive              Boolean  @default(true) @map("is_active")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  hotel                 Hotel                  @relation(fields: [hotelId], references: [id])
  inventory             RoomInventory[]
  bookingItems          BookingItem[]
  inventoryFlashWindows InventoryFlashWindow[]

  @@index([hotelId])
  @@index([tenantId])
  @@map("room_types")
}

model RoomInventory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomTypeId     String   @map("room_type_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  date           DateTime @db.Date
  totalCount     Int      @map("total_count")
  availableCount Int      @map("available_count")
  blockedCount   Int      @default(0) @map("blocked_count")
  pricePerNight  Int      @map("price_per_night")
  minStay        Int      @default(1) @map("min_stay")
  restrictions   Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, date])
  @@index([tenantId])
  @@index([date])
  @@index([roomTypeId, date])
  @@map("room_inventory")
}

// ─────────────────────────────────────────────
// BOOKING (Cross-Domain)
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  hotelId         String        @map("hotel_id") @db.Uuid
  guestId         String        @map("guest_id") @db.Uuid
  bookingType     BookingType   @map("booking_type")
  bookingRef      String        @unique @map("booking_ref")
  status          BookingStatus @default(PENDING)
  checkIn         DateTime?     @map("check_in") @db.Date
  checkOut        DateTime?     @map("check_out") @db.Date
  guestCount      Int           @default(1) @map("guest_count")
  childCount      Int           @default(0) @map("child_count")
  subtotalCents   Int           @map("subtotal_cents")
  taxCents        Int           @default(0) @map("tax_cents")
  feesCents       Int           @default(0) @map("fees_cents")
  discountCents   Int           @default(0) @map("discount_cents")
  totalCents      Int           @map("total_cents")
  currency        String        @default("USD") @db.VarChar(3)
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  specialRequests String?       @map("special_requests") @db.Text
  internalNotes   String?       @map("internal_notes") @db.Text
  cancelledAt     DateTime?     @map("cancelled_at")
  checkedInAt     DateTime?     @map("checked_in_at")
  checkedOutAt    DateTime?     @map("checked_out_at")
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  hotel             Hotel              @relation(fields: [hotelId], references: [id])
  guest             User               @relation(fields: [guestId], references: [id])
  items             BookingItem[]
  supportCases      SupportCase[]
  reviews           Review[]
  guestStaySessions GuestStaySession[]

  @@index([tenantId])
  @@index([hotelId])
  @@index([guestId])
  @@index([status])
  @@index([bookingRef])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model BookingItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId   String   @map("booking_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  itemType    String   @map("item_type")
  referenceId String?  @map("reference_id") @db.Uuid
  description String
  quantity    Int      @default(1)
  unitCents   Int      @map("unit_cents")
  totalCents  Int      @map("total_cents")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  booking  Booking   @relation(fields: [bookingId], references: [id])
  roomType RoomType? @relation(fields: [referenceId], references: [id])

  @@index([bookingId])
  @@index([tenantId])
  @@map("booking_items")
}

// ─────────────────────────────────────────────
// EVENT OS
// ─────────────────────────────────────────────

model Venue {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId          String           @map("hotel_id") @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
  name             String
  description      String?          @db.Text
  floorLevel       String?          @map("floor_level")
  sizeSquareMeters Decimal?         @map("size_square_meters") @db.Decimal(8, 2)
  capacities       Json             @default("{}") // { THEATER: 100, CLASSROOM: 60, ... }
  defaultLayout    VenueLayoutType? @map("default_layout")
  availableLayouts Json             @default("[]") @map("available_layouts")
  features         Json             @default("[]") // ["natural_light", "av_equipment", "private_bar", ...]
  avEquipment      Json             @default("[]") @map("av_equipment")
  cateringOptions  Json             @default("[]") @map("catering_options")
  photos           Json             @default("[]")
  ratePerHour      Int?             @map("rate_per_hour") // cents
  ratePerDay       Int?             @map("rate_per_day") // cents
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  hotel         Hotel          @relation(fields: [hotelId], references: [id])
  eventBookings EventBooking[]

  @@index([hotelId])
  @@index([tenantId])
  @@map("venues")
}

model EventRequest {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  hotelId           String             @map("hotel_id") @db.Uuid
  requesterId       String             @map("requester_id") @db.Uuid
  eventType         EventType          @map("event_type")
  title             String
  description       String?            @db.Text
  eventDate         DateTime           @map("event_date") @db.Date
  startTime         String?            @map("start_time")
  endTime           String?            @map("end_time")
  guestCount        Int                @map("guest_count")
  budgetCents       Int?               @map("budget_cents")
  requirements      Json               @default("{}")
  status            EventRequestStatus @default(INQUIRY)
  assignedManagerId String?            @map("assigned_manager_id") @db.Uuid
  proposalSentAt    DateTime?          @map("proposal_sent_at")
  confirmedAt       DateTime?          @map("confirmed_at")
  internalNotes     String?            @map("internal_notes") @db.Text
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  requester    User          @relation(fields: [requesterId], references: [id])
  eventBooking EventBooking?
  beo          BEO?

  @@index([tenantId])
